# ============================================
# MERN E-Commerce Backend Environment Variables
# ============================================

# ============================================
# Database Configuration
# ============================================
MONGODB_URI=mongodb://localhost:27017/paithani_sarees
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/paithani_sarees

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345
# Note: Use a strong random string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ============================================
# Admin Credentials (for admin login)
# ============================================
ADMIN_EMAIL=admin@paithani.com
ADMIN_PASSWORD=AdminPassword123

# ============================================
# Stripe Payment Gateway
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# Get from: https://dashboard.stripe.com/apikeys

# ============================================
# Cloudinary Image Storage
# ============================================
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# Get from: https://cloudinary.com/console

# ============================================
# Frontend URL (for CORS and redirects)
# ============================================
FRONTEND_URL=http://localhost:5173
# In production: https://yourdomain.com

# ============================================
# Server Configuration
# ============================================
PORT=4000
NODE_ENV=development
# Use: production, development, or testing

# ============================================
# Email Configuration (Optional - for future use)
# ============================================
# EMAIL_SERVICE=gmail
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password

# ============================================
# Logging Configuration (Optional)
# ============================================
# LOG_LEVEL=debug
# LOG_FILE=./logs/app.log
